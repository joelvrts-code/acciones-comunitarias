generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////

model User {
  id       Int     @id @default(autoincrement())
  name     String
  email    String  @unique
  password String
  role     String  @default("editor")
  isActive Boolean @default(true)

  campaigns Campaign[] @relation("UserCampaigns")
  auditLogs AuditLog[]

  createdAt DateTime @default(now())

  @@index([email])
}

//////////////////////////////////////////////////////
// CAMPAIGNS
//////////////////////////////////////////////////////

model Campaign {
  id Int @id @default(autoincrement())

  title       String
  description String

  goal Int @default(100)

  status String @default("pendiente")
  type   String @default("petition")

  creatorName  String?
  creatorEmail String?

  imageUrl String?

  //////////////////////////////////////////////////////
  // EMAIL CAMPAIGNS
  //////////////////////////////////////////////////////

  emailSubject String?
  emailBody    String?
  emailTarget  String?

  //////////////////////////////////////////////////////
  // RELACIÓN CON USER (CREADOR)
  //////////////////////////////////////////////////////

  createdById Int?
  createdBy   User? @relation("UserCampaigns", fields: [createdById], references: [id])

  //////////////////////////////////////////////////////
  // SISTEMA
  //////////////////////////////////////////////////////

  editToken String   @default(uuid())
  createdAt DateTime @default(now())

  //////////////////////////////////////////////////////
  // RELACIONES
  //////////////////////////////////////////////////////

  participants Participant[]
  emailTargets EmailTarget[]
  emailLogs    EmailLog[]
}

//////////////////////////////////////////////////////
// PARTICIPANTS
//////////////////////////////////////////////////////

model Participant {
  id         Int     @id @default(autoincrement())
  name       String
  email      String
  zipCode    String?
  subscribed Boolean @default(true)

  campaignId Int
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  createdAt DateTime @default(now())

  emailLogs EmailLog[]

  @@index([campaignId])
  @@index([email])
}

//////////////////////////////////////////////////////
// EMAIL TARGETS
//////////////////////////////////////////////////////

model EmailTarget {
  id Int @id @default(autoincrement())

  name  String
  email String

  campaignId Int
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  @@index([campaignId])
}

//////////////////////////////////////////////////////
// EMAIL LOGS
//////////////////////////////////////////////////////

model EmailLog {
  id Int @id @default(autoincrement())

  participantId Int
  participant   Participant @relation(fields: [participantId], references: [id])

  campaignId Int
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  sentAt DateTime @default(now())

  @@index([campaignId])
  @@index([participantId])
}

//////////////////////////////////////////////////////
// AUDIT LOG
//////////////////////////////////////////////////////

model AuditLog {
  id Int @id @default(autoincrement())

  action  String
  message String

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
}